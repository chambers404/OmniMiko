<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Never back up model weights; they are large and re-downloadable. -->
        <exclude domain="file" path="models" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="models" />
    </device-transfer>
</data-extraction-rules>
